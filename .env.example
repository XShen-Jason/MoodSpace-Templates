# ── Admin Auth (管理员 API 密钥) ───────────────────────────────────────
# 获取/设置位置: 自己随便编一个强密码（比如一串随机的 UUID 或长字符串）。
# ⚠️ 注意: 必须与后端及 Worker Secret (ADMIN_KEY) 的配置完全一致！
RS_ADMIN_KEY="your_admin_secret_here"

# ── API Endpoint (后端上传网关) ──────────────────────────────────────────
# 获取/设置位置: 填入你部署后端的真实公网 API 域名 (例如 https://api.moodspace.xyz)。
# 作用: 脚本 `scripts/upload-template.js` 会向此地址发送模板原始压缩包及 metadata。
RS_WORKER_URL="https://your-api-url.com"
